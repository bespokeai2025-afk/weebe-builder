# =============================================================================
# WebEspoke AI Builder — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# ---------------------------------------------------------------------------
# Supabase — Core (required)
# ---------------------------------------------------------------------------
# Get these from your Supabase project dashboard > Settings > API
SUPABASE_URL="https://xxxxx.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..._secret_service_role_key"

# Client-side equivalents (Vite exposes these to the browser)
VITE_SUPABASE_URL="https://xxxxx.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_PROJECT_ID="xxxxx"             # optional — only used by some Lovable mail routes

# ---------------------------------------------------------------------------
# Stripe / Payments — required for billing
# ---------------------------------------------------------------------------
# Publishable key (pk_test_... or pk_live_...)
VITE_PAYMENTS_CLIENT_TOKEN="pk_test_..."

# Secret keys — keep secret, never commit
STRIPE_SANDBOX_API_KEY="sk_test_..."
STRIPE_LIVE_API_KEY="sk_live_..."

# Webhook signing secrets (from Stripe dashboard > Webhooks)
PAYMENTS_SANDBOX_WEBHOOK_SECRET="whsec_..."
PAYMENTS_LIVE_WEBHOOK_SECRET="whsec_..."

# ---------------------------------------------------------------------------
# Retell AI — required for voice agent functionality
# ---------------------------------------------------------------------------
RETELL_API_KEY="key_..."
RETELL_WEBHOOK_SECRET="..."                  # from Retell dashboard > Webhooks
RETELL_SIGNATURE_VERIFICATION_ENABLED="false"  # set "true" to enforce HMAC signature on webhooks
# Optional retail mode: when BOTH are set, deploy skips admin approval and all agents
# use this shared Supabase workspace + Retell production key.
RETELL_RETAIL_API_KEY="key_..."             # Retell API key for production clone / live agents
RETAIL_WORKSPACE_ID=""                     # UUID from public.workspaces (run scripts/backfill-retail-workspace.ts)

# Legacy Supabase (for scripts/seed-agent-templates.ts only)
# LEGACY_SUPABASE_URL="https://xxxxx.supabase.co"
# LEGACY_SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# ---------------------------------------------------------------------------
# Lovable Gateway — required for Stripe connector & transactional email
# ---------------------------------------------------------------------------
LOVABLE_API_KEY="lovable_..."
LOVABLE_SEND_URL="https://send.lovable.dev"  # transactional email service

# ---------------------------------------------------------------------------
# Google OAuth — configured via Supabase dashboard, not env vars
# To enable Google sign-in:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create OAuth 2.0 Client ID (Web application)
#   3. Add Authorized redirect URI:
#      https://<project>.supabase.co/auth/v1/callback
#   4. Copy Client ID + Client Secret to Supabase Dashboard:
#      Authentication → Providers → Google → Enable
#   5. Add callback URL to Supabase allowed redirects:
#      Authentication → URL Configuration → Redirect URLs
#      → http://localhost:3000/auth/callback (dev)
#      → https://<your-domain>/auth/callback (prod)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Application URLs
# ---------------------------------------------------------------------------
PUBLIC_SITE_URL="https://yourdomain.com"     # used for agent registration callbacks
PUBLIC_BASE_URL="https://yourdomain.com"     # used for internal redirects
SITE_NAME="webespokegenbuilder"             # used in transactional email templates
SENDER_DOMAIN="notify.yourdomain.com"       # verified sender subdomain for email

# ---------------------------------------------------------------------------
# Admin / Setup
# ---------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@webespokeai.com"     # email for seed-admin.ts script

# ---------------------------------------------------------------------------
# Optional — Supabase Management API (for project-level config)
# ---------------------------------------------------------------------------
# SUPABASE_ACCESS_TOKEN="sbp_..."


GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
