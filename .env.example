# =============================================================================
# WebEspoke AI Builder — Environment Variables (names only)
# =============================================================================
# Copy to .env and fill in values locally or in Replit Secrets.
#   cp .env.example .env
#
# Never commit .env or real secret values to Git.

# --- Supabase (required) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
SUPABASE_ACCESS_TOKEN=

# --- Stripe / payments ---
VITE_PAYMENTS_CLIENT_TOKEN=
STRIPE_SANDBOX_API_KEY=
STRIPE_LIVE_API_KEY=
PAYMENTS_SANDBOX_WEBHOOK_SECRET=
PAYMENTS_LIVE_WEBHOOK_SECRET=

# --- Retell AI ---
RETELL_API_KEY=
RETELL_RETAIL_API_KEY=
RETELL_WEBHOOK_SECRET=
RETELL_SIGNATURE_VERIFICATION_ENABLED=
RETAIL_WORKSPACE_ID=

# --- Upstash Redis (cache) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- AI providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=
OPENAI_REALTIME_INBOUND_URL=

# --- Telephony ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
FREJUN_API_KEY=

# --- n8n (System Mind workflows) ---
N8N_API_KEY=
N8N_API_BASE_URL=

# --- Email ---
LOVABLE_API_KEY=
LOVABLE_SEND_URL=
RESEND_API_KEY=
# RESEND_FROM must be an address on a domain verified in your Resend account
# (Settings > Domains). Without it, sends silently fall back to
# onboarding@resend.dev, which Resend only delivers to the account owner's own
# email — all other recipients (e.g. webform lead notifications) get silently
# dropped with no error surfaced in the app.
RESEND_FROM=
SENDER_DOMAIN=
SITE_NAME=

# --- Google OAuth (optional; often configured in Supabase dashboard) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- Application URLs ---
PUBLIC_SITE_URL=
PUBLIC_BASE_URL=
PUBLIC_URL=

# --- Auth / cron ---
SESSION_SECRET=
CRON_SECRET=
SEED_ADMIN_EMAIL=

# --- WeeBespoke Enterprise (WBAH integration) ---
WEBESPOKE_ADMIN_EMAIL=
WEBESPOKE_ADMIN_PASSWORD=

# --- Legacy Supabase (scripts/seed-agent-templates.ts only) ---
# LEGACY_SUPABASE_URL=
# LEGACY_SUPABASE_SERVICE_ROLE_KEY=

# --- Replit (auto-injected on Replit; leave unset elsewhere) ---
# REPLIT_DEV_DOMAIN=
