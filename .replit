modules = ["nodejs-22", "python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8799
externalPort = 3001

[[ports]]
localPort = 8801
externalPort = 3003

[[ports]]
localPort = 8802
externalPort = 4200

[[ports]]
localPort = 8803
externalPort = 5000

[[ports]]
localPort = 8804
externalPort = 5173

[[ports]]
localPort = 8805
externalPort = 6000

[[ports]]
localPort = 8810
externalPort = 6800

[[ports]]
localPort = 8811
externalPort = 8000

[[ports]]
localPort = 8812
externalPort = 8008

[[ports]]
localPort = 23636
externalPort = 8081

[userenv]

[userenv.shared]
RETELL_SIGNATURE_VERIFICATION_ENABLED = "true"
WEBESPOKE_ADMIN_EMAIL = "nathan@bespoke.ai"
RETELL_FORWARD_N8N_WEBHOOK_URL = "https://bespoke.app.n8n.cloud/webhook/392d5d13-7ee2-4fa0-ad46-7736ba4603bf"

[userenv.production]
PUBLIC_BASE_URL = "https://webeebuilder.com"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "run", "start"]
build = ["bash", "-c", "NODE_OPTIONS='--max-old-space-size=4096' npm run build"]
